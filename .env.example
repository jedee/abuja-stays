# AbujaStays — Firebase + App Configuration
# Copy this file to .env and fill in the values

# Firebase (required for real data)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Mode
# Set to "true" to use localStorage instead of Firebase (no setup needed)
VITE_USE_MOCK=true

# Optional: Mapbox for map (get free token at mapbox.com)
VITE_MAPBOX_TOKEN=
